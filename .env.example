# --- LLM provider (pick at least one; all have free tiers) ---
# Groq — fastest free tier, Llama 3.3 70B. https://console.groq.com/keys
GROQ_API_KEY=

# Google AI Studio — Gemini 2.0 Flash free tier. https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# OpenRouter — many free models. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Which provider/model to use by default (groq | google | openrouter)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# --- Optional: Tavily web search (better than free DuckDuckGo). https://tavily.com ---
TAVILY_API_KEY=
